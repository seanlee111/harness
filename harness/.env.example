## Copy this file to .env and fill in your values.
## The project auto-loads .env via dotenv in the CLI / redteam entrypoints.

VOLCENGINE_API_KEY="your-key"
VOLCENGINE_BASE_URL="https://your-openai-compatible-base-url"
VOLCENGINE_MODEL="your-model-name"

# Optional:
# PERSONA_PATH="personas/default.yaml"
# HARNESS_POLICY_PATH="policies/default.yaml"
# REDTEAM_CASES="redteam/default.json"
